# ============================================================
# DeepShade – Git Ignore Rules
# ============================================================

# ----- Large Dataset & Model Files -----
dataset/
*.ckpt
*.pt
*.pth
*.bin
*.h5
*.hdf5
*.safetensors
*.pkl
*.pickle
*.npy
*.npz

# ----- Archive / Compressed Files -----
*.zip
*.tar
*.tar.gz
*.tar.bz2
*.gz
*.7z
*.rar

# ----- Python Cache -----
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ----- Jupyter Notebooks -----
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# ----- IDE & Editor -----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----- Logs & Outputs -----
logs/
lightning_logs/
wandb/
*.log
outputs/

# ----- Environment -----
.env
.env.*
venv/
.venv/
env/

# ----- Experiment / Scratch Folders -----
ControlNet_edge_contra2/
.history/

# ----- Git pack files (nested .git) -----
ControlNet/.git
*.rev
*.pack
*.idx

# ----- CSV / Data snapshots -----
*.csv

# ----- Font files -----
*.ttf
*.otf
